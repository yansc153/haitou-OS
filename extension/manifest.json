{
  "manifest_version": 3,
  "name": "海投助手 Browser Bridge",
  "version": "1.1.0",
  "description": "一键连接求职平台 — 海投助手自动化求职的浏览器桥接组件",
  "permissions": [
    "cookies",
    "tabs"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.zhaopin.com/*",
    "*://*.lagou.com/*",
    "*://*.zhipin.com/*",
    "*://*.liepin.com/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://*.haitou.app/*",
      "https://*.vercel.app/*",
      "https://*.supabase.co/*",
      "http://localhost:3000/*",
      "http://localhost:3001/*"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.haitou.app/*",
        "https://*.vercel.app/*",
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
